<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <RelativeLayout
        android:layout_marginBottom="130dp"
        android:layout_marginTop="0dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/bt_addcart">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="3dp"
                    android:padding="5dp"
                    android:orientation="vertical">

                    <com.daimajia.slider.library.SliderLayout
                        android:id="@+id/slider"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_margin="0dp" />

<!--                    <TextView-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_marginTop="10dp"-->
<!--                        android:fontFamily="@font/custom_font"-->
<!--                        android:text="Shop from Top Categories"-->
<!--                        android:textColor="@color/black"-->
<!--                        android:textSize="16dp"-->
<!--                        android:textStyle="bold" />-->

                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmer_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:animateLayoutChanges="true"
                        android:animationCache="true"
                        app:shimmer_repeat_mode="restart"
                        app:shimmer_shape="radial">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:weightSum="3"
                            android:orientation="horizontal">

                            <include layout="@layout/item_cat_shimmer" />
                            <include layout="@layout/item_cat_shimmer" />
                            <include layout="@layout/item_cat_shimmer" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:weightSum="3"
                            android:orientation="horizontal">

                            <include layout="@layout/item_cat_shimmer" />
                            <include layout="@layout/item_cat_shimmer" />
                            <include layout="@layout/item_cat_shimmer" />

                        </LinearLayout>

                        </LinearLayout>
                    </com.facebook.shimmer.ShimmerFrameLayout>


                    <androidx.recyclerview.widget.RecyclerView
                        android:orientation="horizontal"
                        android:scrollbars="horizontal"
                        android:id="@+id/rvcat"
                        android:visibility="gone"
                        android:layout_marginTop="2dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />



<!--                    <TextView-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_marginTop="10dp"-->
<!--                        android:fontFamily="@font/custom_font"-->
<!--                        android:text="Shop from Top Categories"-->
<!--                        android:textColor="@color/black"-->
<!--                        android:textSize="16dp"-->
<!--                        android:textStyle="bold" />-->

<!--                    <androidx.recyclerview.widget.RecyclerView-->
<!--                        android:orientation="vertical"-->
<!--                        android:scrollbars="vertical"-->
<!--                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"-->
<!--                        android:id="@+id/rvcat"-->
<!--                        android:layout_marginTop="5dp"-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="wrap_content" />-->

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/custom_font"
                            android:layout_weight="1"
                            android:text="Most Ordered Products"
                            android:textColor="@color/black"
                            android:textSize="16dp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnmostmore"
                            android:text="See More"
                            android:textColor="@color/red"
                            android:layout_margin="5dp"
                            android:textAllCaps="false"
                            android:fontFamily="@font/custom_font"
                            android:background="@drawable/btn_org"
                            android:layout_width="150dp"
                            android:layout_height="35dp"/>

                    </LinearLayout>



                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmer_product"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:animateLayoutChanges="true"
                        android:animationCache="true"
                        app:shimmer_repeat_mode="restart"
                        app:shimmer_shape="radial">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:weightSum="2"
                            android:orientation="horizontal">

                            <include layout="@layout/item_prd_shimmer" />
                            <include layout="@layout/item_prd_shimmer" />


                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:weightSum="2"
                            android:orientation="horizontal">

                            <include layout="@layout/item_prd_shimmer" />
                            <include layout="@layout/item_prd_shimmer" />


                        </LinearLayout>

                        </LinearLayout>

                    </com.facebook.shimmer.ShimmerFrameLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_marginTop="5dp"
                        android:id="@+id/rvprd"
                        android:orientation="vertical"
                        android:scrollbars="vertical"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <com.daimajia.slider.library.SliderLayout
                        android:id="@+id/slider2"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginTop="10dp" />

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="0dp"
                            android:fontFamily="@font/custom_font"
                            android:text="Recent View"
                            android:layout_weight="1"
                            android:textColor="@color/black"
                            android:textSize="16dp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnviewmore"
                            android:text="See More"
                            android:textColor="@color/red"
                            android:layout_margin="5dp"
                            android:textAllCaps="false"
                            android:fontFamily="@font/custom_font"
                            android:background="@drawable/btn_org"
                            android:layout_width="150dp"
                            android:layout_height="35dp"/>

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_marginTop="5dp"
                        android:id="@+id/rvrview"
                        android:orientation="vertical"
                        android:scrollbars="vertical"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvcategory"
                        android:background="@color/greylgt3"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:scrollbars="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>


                    <com.daimajia.slider.library.SliderLayout
                        android:id="@+id/slider3"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_margin="3dp" />

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/custom_font"
                            android:text="End Year Sale"
                            android:textColor="@color/black"
                            android:textSize="16dp"
                            android:layout_weight="1"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnsalemore"
                            android:text="See More"
                            android:textColor="@color/red"
                            android:layout_margin="5dp"
                            android:textAllCaps="false"
                            android:fontFamily="@font/custom_font"
                            android:background="@drawable/btn_org"
                            android:layout_width="150dp"
                            android:layout_height="35dp"/>

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:orientation="vertical"
                        android:scrollbars="vertical"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:layout_marginTop="5dp"
                        android:id="@+id/rvend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <com.daimajia.slider.library.SliderLayout
                        android:id="@+id/slider4"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_margin="3dp" />

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_weight="1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/custom_font"
                            android:text="Today's Deal"
                            android:textColor="@color/black"
                            android:textSize="16dp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btndealmore"
                            android:text="See More"
                            android:textColor="@color/red"
                            android:layout_margin="5dp"
                            android:textAllCaps="false"
                            android:fontFamily="@font/custom_font"
                            android:background="@drawable/btn_org"
                            android:layout_width="150dp"
                            android:layout_height="35dp"/>

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:orientation="vertical"
                        android:scrollbars="vertical"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:id="@+id/rvdeal"
                        android:layout_marginTop="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </RelativeLayout>


