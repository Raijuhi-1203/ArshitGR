<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/click"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:padding="3dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:elevation="12dp"
        android:focusable="true"
        android:layout_weight="1"
        app:cardCornerRadius="15dp">

        <LinearLayout
            android:background="@color/white"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:scaleType="fitXY"
                android:layout_gravity="center"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:id="@+id/rimg"
                android:src="@drawable/fbanner2"/>

            <TextView
                android:textColor="@color/white"
                android:padding="10dp"
                android:textSize="17dp"
                android:id="@+id/name"
                android:textStyle="bold"
                android:background="@color/trblack2"
                android:fontFamily="@font/custom_font"
                android:text="Diamond's Pizza"
                android:layout_marginTop="-50dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:textColor="@color/black"
                android:padding="10dp"
                android:id="@+id/add"
                android:textSize="15dp"
                android:textStyle="bold"
                android:fontFamily="@font/custom_font"
                android:text="35-45 min  1 km"
                android:background="@color/white"
                android:layout_margin="0dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:textStyle="bold"
                android:textColor="@color/red"
                android:padding="5dp"
                android:textSize="15dp"
                android:fontFamily="@font/custom_font"
                android:text="  3.8 "
                android:drawableEnd="@drawable/baseline_star_border_24"
                android:id="@+id/rating"
                android:drawableTint="@color/red"
                android:layout_marginRight="10dp"
                android:textAlignment="textEnd"
                android:background="@drawable/btn_org"
                android:layout_marginTop="-35dp"
                android:layout_gravity="end"
                android:layout_width="wrap_content"
                android:layout_height="30dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>