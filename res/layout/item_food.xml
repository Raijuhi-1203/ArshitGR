<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/click_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:background="@drawable/product_box"
    android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="5dp">

            <ImageView
                android:id="@+id/prdimg"
                android:adjustViewBounds="true"
                android:padding="2dp"
                android:scaleType="centerInside"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_margin="3dp"
                android:orientation="vertical"
                android:padding="5dp">

            <TextView
                android:id="@+id/prdnm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAlignment="textStart"
                android:maxLength="26"
                android:fontFamily="@font/custom_font"
                android:singleLine="true"
                android:textColor="@color/black"
                android:textSize="14dp" />

            <LinearLayout
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:fontFamily="@font/custom_font"
                    android:layout_marginLeft="10dp"
                    android:id="@+id/offmrp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:textColor="@color/green"
                    android:textSize="16dp"
                    android:textStyle="bold" />

                <TextView
                    android:fontFamily="@font/custom_font"
                    android:layout_marginLeft="15dp"
                    android:id="@+id/mrp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:textColor="@color/grey"
                    android:textSize="16dp"
                    android:textStyle="bold" />


                <TextView
                    android:fontFamily="@font/custom_font"
                    android:layout_marginLeft="0dp"
                    android:id="@+id/unit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="textStart"
                    android:textColor="@color/black"
                    android:textSize="16dp"
                    android:textStyle="bold" />
            </LinearLayout>



            <Button
                android:id="@+id/btncart"
                android:padding="8dp"
                android:textSize="14dp"
                android:fontFamily="@font/custom_font"
                android:layout_width="160dp"
                android:layout_height="35dp"
                android:layout_gravity="start"
                android:textAllCaps="false"
                android:background="@drawable/btnorange"
                android:text="Add To Cart"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:textColor="@color/white" />

            <LinearLayout
                android:id="@+id/cart_qty"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:background="@drawable/btngrey"
                android:gravity="center">


                <ImageView
                    android:id="@+id/minus"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="5dp"
                    android:src="@drawable/baseline_remove_circle_24" />


                <TextView
                    android:fontFamily="@font/custom_font"
                    android:id="@+id/cartno"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_margin="5dp"
                    android:gravity="center"
                    android:text="0"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="16dp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/add"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_margin="5dp"
                    android:src="@drawable/baseline_add_circle_24" />


            </LinearLayout>

        </LinearLayout>
        </LinearLayout>

    <ImageView
        android:id="@+id/nclick"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_margin="5dp"
        android:visibility="gone"
        android:layout_gravity="right|end"
        android:src="@drawable/non_clickable" />

    <ImageView
        android:id="@+id/click"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_gravity="right|end"
        android:layout_margin="5dp"
        android:src="@drawable/clickable"
        android:visibility="gone" />

    <TextView
        android:id="@+id/dismrp"
        android:layout_width="30dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:textStyle="bold"
        android:visibility="gone"
        android:textAlignment="center"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:layout_gravity="left|end"
        android:textColor="@color/white"
        android:textSize="8dp"
        android:text="₹ 7\noff" />

    <ImageView
        android:layout_width="40dp"
        android:layout_height="47dp"
        android:layout_marginTop="-8dp"
        android:layout_marginLeft="5dp"
        android:id="@+id/offimg"
        android:visibility="gone"
        android:layout_gravity="left|end"
        android:src="@drawable/discount" />

</LinearLayout>