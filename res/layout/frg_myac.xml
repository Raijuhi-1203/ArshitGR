<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".Fragment.AccountFragment"
        android:orientation="vertical">

        <include layout="@layout/header"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <androidx.core.widget.NestedScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_above="@+id/bt_addcart">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="10dp"
                            android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="0dp"
                            android:padding="10dp"
                            android:background="@color/white"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txname"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/custom_font"
                                android:textAlignment="center"
                                android:textColor="@color/black"
                                android:textSize="16dp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txmob"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/custom_font"
                                android:textAlignment="center"
                                android:textColor="@color/black"
                                android:textSize="16dp" />

                        </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:fontFamily="@font/custom_font"
                                android:text="Your Information"
                                android:textAlignment="textStart"
                                android:textColor="@color/black"
                                android:textSize="16dp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_margin="5dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:weightSum="2">

                                <androidx.cardview.widget.CardView
                                    android:id="@+id/btnohistory"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:elevation="12dp"
                                    android:focusable="true"
                                    android:layout_weight="1"
                                    app:cardCornerRadius="8dp">

                                    <LinearLayout
                                        android:background="@color/white"
                                        android:orientation="vertical"
                                        android:layout_width="match_parent"
                                        android:layout_height="90dp">

                                        <ImageView
                                            android:layout_gravity="center"
                                            android:layout_width="50dp"
                                            android:padding="10dp"
                                            android:layout_height="50dp"
                                            android:src="@drawable/order" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="center"
                                            android:text="Order History"
                                            android:textAllCaps="false"
                                            android:textColor="@color/black"
                                            android:textSize="14dp"
                                            android:layout_marginBottom="5dp"
                                            />

                                    </LinearLayout>

                                </androidx.cardview.widget.CardView>

                                <androidx.cardview.widget.CardView
                                    android:padding="3dp"
                                    android:id="@+id/btnpinfo"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:elevation="12dp"
                                    android:focusable="true"
                                    android:layout_weight="1"
                                    app:cardCornerRadius="8dp">

                                    <LinearLayout
                                        android:background="@color/white"
                                        android:orientation="vertical"
                                        android:layout_width="match_parent"
                                        android:layout_height="90dp">

                                        <ImageView
                                            android:padding="10dp"
                                            android:layout_gravity="center"
                                            android:layout_width="50dp"
                                            android:layout_height="50dp"
                                            android:src="@drawable/user" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="center"
                                            android:text="Profile Info"
                                            android:textAllCaps="false"
                                            android:textColor="@color/black"
                                            android:textSize="14dp"
                                            />

                                    </LinearLayout>

                                </androidx.cardview.widget.CardView>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_margin="5dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:weightSum="2">

                                <androidx.cardview.widget.CardView
                                    android:id="@+id/btaddress"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:elevation="12dp"
                                    android:focusable="true"
                                    android:layout_weight="1"
                                    app:cardCornerRadius="8dp">

                                    <LinearLayout
                                        android:background="@color/white"
                                        android:orientation="vertical"
                                        android:layout_width="match_parent"
                                        android:layout_height="90dp">

                                        <ImageView
                                            android:layout_gravity="center"
                                            android:layout_width="50dp"
                                            android:padding="10dp"
                                            android:layout_height="50dp"
                                            android:src="@drawable/address" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="center"
                                            android:text="Address Book"
                                            android:textAllCaps="false"
                                            android:textColor="@color/black"
                                            android:textSize="14dp"
                                            android:layout_marginBottom="5dp"
                                            />

                                    </LinearLayout>

                                </androidx.cardview.widget.CardView>

                                <androidx.cardview.widget.CardView
                                    android:padding="3dp"
                                    android:id="@+id/btncorder"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:elevation="12dp"
                                    android:focusable="true"
                                    android:layout_weight="1"
                                    app:cardCornerRadius="8dp">

                                    <LinearLayout
                                        android:background="@color/white"
                                        android:orientation="vertical"
                                        android:layout_width="match_parent"
                                        android:layout_height="90dp">

                                        <ImageView
                                            android:padding="10dp"
                                            android:layout_gravity="center"
                                            android:layout_width="50dp"
                                            android:layout_height="50dp"
                                            android:src="@drawable/cancel" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="center"
                                            android:text="Cancelled Order"
                                            android:textAllCaps="false"
                                            android:textColor="@color/black"
                                            android:textSize="14dp"
                                            />

                                    </LinearLayout>

                                </androidx.cardview.widget.CardView>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_margin="5dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:weightSum="2">

                                <androidx.cardview.widget.CardView
                                    android:id="@+id/btnwish"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:elevation="12dp"
                                    android:focusable="true"
                                    android:layout_weight="1"
                                    app:cardCornerRadius="8dp">

                                    <LinearLayout
                                        android:background="@color/white"
                                        android:orientation="vertical"
                                        android:layout_width="match_parent"
                                        android:layout_height="90dp">

                                        <ImageView
                                            android:layout_gravity="center"
                                            android:layout_width="50dp"
                                            android:padding="10dp"
                                            android:layout_height="50dp"
                                            android:src="@drawable/love" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="center"
                                            android:text="Your WishList"
                                            android:textAllCaps="false"
                                            android:textColor="@color/black"
                                            android:textSize="14dp"
                                            android:layout_marginBottom="5dp"
                                            />

                                    </LinearLayout>

                                </androidx.cardview.widget.CardView>

                                <androidx.cardview.widget.CardView
                                    android:padding="3dp"
                                    android:id="@+id/btnsupport"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:elevation="12dp"
                                    android:focusable="true"
                                    android:layout_weight="1"
                                    app:cardCornerRadius="8dp">

                                    <LinearLayout
                                        android:background="@color/white"
                                        android:orientation="vertical"
                                        android:layout_width="match_parent"
                                        android:layout_height="90dp">

                                        <ImageView
                                            android:padding="10dp"
                                            android:layout_gravity="center"
                                            android:layout_width="50dp"
                                            android:layout_height="50dp"
                                            android:src="@drawable/support" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="center"
                                            android:text="Customer Support"
                                            android:textAllCaps="false"
                                            android:textColor="@color/black"
                                            android:textSize="14dp"
                                            />

                                    </LinearLayout>

                                </androidx.cardview.widget.CardView>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_margin="5dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:weightSum="2">

                                <androidx.cardview.widget.CardView
                                    android:id="@+id/btnabout"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:elevation="12dp"
                                    android:focusable="true"
                                    android:layout_weight="1"
                                    app:cardCornerRadius="8dp">

                                    <LinearLayout
                                        android:background="@color/white"
                                        android:orientation="vertical"
                                        android:layout_width="match_parent"
                                        android:layout_height="90dp">

                                        <ImageView
                                            android:layout_gravity="center"
                                            android:layout_width="50dp"
                                            android:padding="10dp"
                                            android:layout_height="50dp"
                                            android:src="@drawable/about" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="center"
                                            android:text="About Us"
                                            android:textAllCaps="false"
                                            android:textColor="@color/black"
                                            android:textSize="14dp"
                                            android:layout_marginBottom="5dp"
                                            />

                                    </LinearLayout>

                                </androidx.cardview.widget.CardView>

                                <androidx.cardview.widget.CardView
                                    android:padding="3dp"
                                    android:id="@+id/btnlogout"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:elevation="12dp"
                                    android:focusable="true"
                                    android:layout_weight="1"
                                    app:cardCornerRadius="8dp">

                                    <LinearLayout
                                        android:background="@color/white"
                                        android:orientation="vertical"
                                        android:layout_width="match_parent"
                                        android:layout_height="90dp">

                                        <ImageView
                                            android:padding="10dp"
                                            android:layout_gravity="center"
                                            android:layout_width="50dp"
                                            android:layout_height="50dp"
                                            android:src="@drawable/logout" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="center"
                                            android:text="LogOut"
                                            android:textAllCaps="false"
                                            android:textColor="@color/black"
                                            android:textSize="14dp"
                                            />

                                    </LinearLayout>

                                </androidx.cardview.widget.CardView>

                            </LinearLayout>



                        </LinearLayout>
                    </androidx.core.widget.NestedScrollView>
                </LinearLayout>

            </RelativeLayout>

            <include layout="@layout/bottom_navigation"/>

        </RelativeLayout>

    </LinearLayout>

</LinearLayout>