<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".Fragment.ShopFragment"
        android:orientation="vertical">

        <include layout="@layout/header"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.core.widget.NestedScrollView
                    android:layout_marginBottom="70dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/category" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Categories"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/offer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/percent" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Offerzone"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/order"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/booking" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="My Order"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/carts"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/cart" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="My Cart"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/wish"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/love" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="My Wishlist"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/acc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/user" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="My Account"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>



                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/contact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/contact" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Contact"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/rate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/star" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Rate Us"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/share"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/share" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Share"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/faq"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/faqw" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="FAQ"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/about"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/about" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="About"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/term"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/term" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Term &amp; Condition"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/privacy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/privacy" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Privacy Policy"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/refund"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/refund" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Refund &amp; Cancle"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/developer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/developer" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Developer"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/lg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/logout" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Logout"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/track"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/track" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Track Order"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>



                    </LinearLayout>

                </LinearLayout>
                </androidx.core.widget.NestedScrollView>

            </RelativeLayout>

            <include layout="@layout/bottom_navigation"/>

        </RelativeLayout>
    </LinearLayout>
</LinearLayout>